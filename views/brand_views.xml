<odoo>
    <record id="view_brand_list" model="ir.ui.view">
        <field name="name">brand.list</field>
        <field name="model">car.brand</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="agency_id"/>
            </list>
        </field>
    </record>
    <record id="view_brand_form" model="ir.ui.view">
        <field name="name">brand.form</field>
        <field name="model">car.brand</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="image"/>
                        <field name="description"/>
                        <field name="agency_id"
                               can_create="false"
                               can_write="false"
                               options="{'no_create': True, 'no_create_edit': True}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_brand" model="ir.actions.act_window">
        <field name="name">Brands</field>
        <field name="res_model">car.brand</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_brand"

              name="Brands"

              parent="menu_car_root"

              action="action_brand"/>
</odoo>
